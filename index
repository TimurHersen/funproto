<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kadıköy — Daire Fiyat Haritası</title>

  <!-- Leaflet -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>

  <!-- Chart.js -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg:        #0e0f13;
      --surface:   #16181f;
      --border:    #2a2d38;
      --gold:      #c9a84c;
      --gold-dim:  #8a6e2f;
      --text:      #e8e4dc;
      --muted:     #7a7d8a;
      --red:       #e05c5c;
      --green:     #4caf7d;
      --blue:      #5b8dee;
      --panel-w:   380px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      height: 100vh;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    /* ── Header ── */
    header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      height: 58px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      z-index: 1000;
      flex-shrink: 0;
    }

    .logo {
      display: flex;
      align-items: baseline;
      gap: 10px;
    }

    .logo h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      color: var(--gold);
      letter-spacing: 0.02em;
    }

    .logo span {
      font-size: 0.72rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .header-meta {
      display: flex;
      align-items: center;
      gap: 20px;
      font-size: 0.78rem;
      color: var(--muted);
    }

    .badge {
      background: rgba(201,168,76,0.12);
      border: 1px solid var(--gold-dim);
      color: var(--gold);
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* ── Layout ── */
    .main {
      display: flex;
      flex: 1;
      overflow: hidden;
    }

    /* ── Map ── */
    #map {
      flex: 1;
      z-index: 1;
    }

    /* ── Sidebar ── */
    #sidebar {
      width: var(--panel-w);
      background: var(--surface);
      border-left: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      transition: width 0.35s cubic-bezier(.4,0,.2,1);
      z-index: 500;
    }

    #sidebar.collapsed { width: 0; }

    .sidebar-header {
      padding: 20px 22px 14px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    .sidebar-header .area-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      color: var(--text);
      line-height: 1.2;
    }

    .sidebar-header .area-sub {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 3px;
    }

    .price-hero {
      display: flex;
      align-items: baseline;
      gap: 6px;
      margin-top: 12px;
    }

    .price-hero .big {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      color: var(--gold);
      line-height: 1;
    }

    .price-hero .unit {
      font-size: 0.78rem;
      color: var(--muted);
    }

    .price-change {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 0.75rem;
      padding: 2px 8px;
      border-radius: 12px;
      margin-left: 8px;
    }

    .price-change.up { background: rgba(76,175,125,0.15); color: var(--green); }
    .price-change.dn { background: rgba(224,92,92,0.12); color: var(--red); }

    .stats-row {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 1px;
      background: var(--border);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    .stat-cell {
      background: var(--surface);
      padding: 14px 16px;
      text-align: center;
    }

    .stat-cell .val {
      font-size: 1.05rem;
      font-weight: 500;
      color: var(--text);
    }

    .stat-cell .lbl {
      font-size: 0.65rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-top: 2px;
    }

    .sidebar-body {
      flex: 1;
      overflow-y: auto;
      padding: 18px 22px;
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }

    .chart-block {
      margin-bottom: 24px;
    }

    .chart-title {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .chart-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .chart-wrap {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 12px;
    }

    .listing-tag {
      display: inline-block;
      font-size: 0.68rem;
      padding: 4px 10px;
      border-radius: 4px;
      border: 1px solid var(--border);
      color: var(--muted);
      margin: 2px 3px;
    }

    .listing-tag.active {
      border-color: var(--gold-dim);
      color: var(--gold);
      background: rgba(201,168,76,0.08);
    }

    /* ── Placeholder ── */
    .placeholder {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
      text-align: center;
      gap: 10px;
      color: var(--muted);
    }

    .placeholder .icon {
      font-size: 2rem;
      opacity: 0.4;
    }

    .placeholder p {
      font-size: 0.82rem;
      line-height: 1.6;
    }

    /* ── Legend ── */
    .legend {
      position: absolute;
      bottom: 24px;
      left: 18px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 12px 16px;
      z-index: 800;
      min-width: 160px;
    }

    .legend-title {
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .legend-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 5px;
      font-size: 0.72rem;
      color: var(--text);
    }

    .legend-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* ── Pin marker for the specific address ── */
    .pin-label {
      background: var(--gold);
      color: #0e0f13;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.65rem;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 4px;
      white-space: nowrap;
      box-shadow: 0 2px 8px rgba(0,0,0,0.5);
    }

    /* Leaflet overrides */
    .leaflet-popup-content-wrapper {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      box-shadow: 0 8px 32px rgba(0,0,0,0.6);
    }
    .leaflet-popup-tip { background: var(--surface); }
    .leaflet-popup-content { margin: 12px 16px; font-family: 'DM Sans', sans-serif; }
    .leaflet-container { background: #0a0b0e; }

    /* Collapse button */
    #collapse-btn {
      position: absolute;
      top: 50%;
      right: 0;
      transform: translateY(-50%) translateX(100%);
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: none;
      color: var(--muted);
      cursor: pointer;
      padding: 8px 5px;
      border-radius: 0 4px 4px 0;
      font-size: 0.8rem;
      z-index: 600;
      line-height: 1;
    }

    #collapse-btn:hover { color: var(--gold); }

    .sidebar-inner { position: relative; height: 100%; display: flex; flex-direction: column; }

    /* Scroll bar */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
  </style>
</head>
