const TARGET = { lat: 40.9893, lng: 29.0261, label: "Reşitpaşa Sok. No:10" };
const MONTHS = ["Kas'24","Ara'24","Oca'25","Şub'25","Mar'25","Nis'25","May'25"];

// ── Color by price ──────────────────────────────────────────
function priceColor(p) {
  if (p >= 90000) return "#e05c5c";
  if (p >= 70000) return "#e08c3c";
  if (p >= 55000) return "#c9a84c";
  return "#4caf7d";
}

function fmt(n) {
  return n.toLocaleString("tr-TR");
}

// ── Charts ─────────────────────────────────────────────────
let trendChart = null, roomChart = null;

function renderCharts(nb) {
  // destroy old
  if (trendChart) { trendChart.destroy(); trendChart = null; }
  if (roomChart)  { roomChart.destroy();  roomChart = null; }

  // Trend
  const tCtx = document.getElementById("trendChart").getContext("2d");
  trendChart = new Chart(tCtx, {
    type: "line",
    data: {
      labels: MONTHS,
      datasets: [{
        label: "₺/m²",
        data: nb.trend,
        borderColor: "#c9a84c",
        backgroundColor: "rgba(201,168,76,0.08)",
        borderWidth: 2,
        pointRadius: 3,
        pointBackgroundColor: "#c9a84c",
        fill: true,
        tension: 0.4
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { color: "#7a7d8a", font: { size: 10 } }, grid: { color: "#1f2130" } },
        y: {
          ticks: {
            color: "#7a7d8a", font: { size: 10 },
            callback: v => (v/1000).toFixed(0)+"K ₺"
          },
          grid: { color: "#1f2130" }
        }
      }
    }
  });

  // Room types
  const rCtx = document.getElementById("roomChart").getContext("2d");
  const rooms = Object.keys(nb.roomTypes);
  const counts = Object.values(nb.roomTypes);
  roomChart = new Chart(rCtx, {
    type: "bar",
    data: {
      labels: rooms,
      datasets: [{
        data: counts,
        backgroundColor: ["rgba(91,141,238,0.7)","rgba(201,168,76,0.7)","rgba(76,175,125,0.7)","rgba(224,92,92,0.7)"],
        borderRadius: 4,
        borderSkipped: false
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { color: "#7a7d8a", font: { size: 10 } }, grid: { color: "#1f2130" } },
        y: { ticks: { color: "#7a7d8a", font: { size: 10 } }, grid: { color: "#1f2130" } }
      }
    }
  });
}

