        <div class="chart-title">Fiyat Aralığı</div>
        <div style="background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:14px 16px;">
          <div style="display:flex;justify-content:space-between;font-size:0.75rem;color:var(--muted);margin-bottom:6px">
            <span>Min</span><span>Max</span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:0.88rem;font-weight:500">
            <span style="color:var(--green)">${(nb.minPrice/1000000).toFixed(1)}M ₺</span>
            <span style="color:var(--red)">${(nb.maxPrice/1000000).toFixed(1)}M ₺</span>
          </div>
          <div style="margin-top:8px;height:4px;background:var(--border);border-radius:2px;position:relative">
            <div style="position:absolute;left:0;top:0;height:100%;width:100%;background:linear-gradient(90deg,var(--green),var(--gold),var(--red));border-radius:2px;opacity:0.6"></div>
          </div>
        </div>
      </div>

      <div class="chart-block" style="margin-bottom:0">
        <div class="chart-title">Oda Tipleri</div>
        <div>
          ${Object.entries(nb.roomTypes).map(([k,v]) => `<span class="listing-tag active">${k}: ${v} ilan</span>`).join("")}
        </div>
      </div>

    </div>
  `;

  // Render charts after DOM is ready
  setTimeout(() => renderCharts(nb), 30);

  // Ensure sidebar open
  document.getElementById("sidebar").classList.remove("collapsed");
  document.getElementById("collapse-btn").textContent = "›";
}

let sidebarOpen = true;
function toggleSidebar() {
  sidebarOpen = !sidebarOpen;
  document.getElementById("sidebar").classList.toggle("collapsed", !sidebarOpen);
  document.getElementById("collapse-btn").textContent = sidebarOpen ? "›" : "‹";
}

// ── Map ────────────────────────────────────────────────────
const map = L.map("map", {
  center: [40.9850, 29.0350],
  zoom: 13,
  zoomControl: false
});

L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png", {
  attribution: '© <a href="https://carto.com/">CARTO</a> © OpenStreetMap contributors',
  maxZoom: 19
}).addTo(map);

L.control.zoom({ position: "topleft" }).addTo(map);

// Neighborhood circles
neighborhoods.forEach(nb => {
  const color = priceColor(nb.pricePerM2);
  const radius = 200 + (nb.listings / 600) * 300;

  const circle = L.circle([nb.lat, nb.lng], {
    radius: radius,
    color: color,
    fillColor: color,
    fillOpacity: 0.25,
    weight: 1.5,
    opacity: 0.7
  }).addTo(map);

  // Label
  const labelIcon = L.divIcon({
    className: "",
    html: `<div style="
      background:rgba(14,15,19,0.85);
      border:1px solid ${color};
      color:${color};
      font-family:'DM Sans',sans-serif;
      font-size:10px;
      font-weight:500;
      padding:3px 7px;
      border-radius:4px;
      white-space:nowrap;
      backdrop-filter:blur(4px);
      box-shadow:0 2px 8px rgba(0,0,0,0.5)
    ">${nb.name}<br><span style="font-size:9px;opacity:0.8">${(nb.pricePerM2/1000).toFixed(0)}K ₺/m²</span></div>`,
    iconAnchor: [0, 0]
  });

  L.marker([nb.lat, nb.lng], { icon: labelIcon, interactive: false }).addTo(map);

  circle.on("click", () => openNeighborhood(nb));
  circle.on("mouseover", function() { this.setStyle({ fillOpacity: 0.45, weight: 2.5 }); });
  circle.on("mouseout",  function() { this.setStyle({ fillOpacity: 0.25, weight: 1.5 }); });
});

// ── Target address marker ────────────────────────────────────
const pinIcon = L.divIcon({
  className: "",
  html: `
    <div style="display:flex;flex-direction:column;align-items:center">
      <div class="pin-label">📍 Reşitpaşa Sok. No:10</div>
      <div style="width:2px;height:10px;background:#c9a84c;margin-top:2px"></div>
      <div style="width:8px;height:8px;border-radius:50%;background:#c9a84c;box-shadow:0 0 10px #c9a84c88"></div>
    </div>`,
  iconAnchor: [60, 30]
});

L.marker([TARGET.lat, TARGET.lng], { icon: pinIcon, zIndexOffset: 1000 })
  .addTo(map)
  .on("click", () => {
    const nb = neighborhoods.find(n => n.id === "resitpasa");
    if (nb) openNeighborhood(nb);
  });

// ── Auto-open Reşitpaşa ─────────────────────────────────────
setTimeout(() => {
  openNeighborhood(neighborhoods.find(n => n.id === "resitpasa"));
}, 500);
</script>
</body>
</html>
